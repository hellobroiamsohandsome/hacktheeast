{
  "manifest_version": 3,
  "name": "ReadFluent Quick Capture",
  "description": "Persistent side panel: capture URL + highlighted text and create ReadFluent lessons.",
  "version": "1.0.0",
  "action": {
    "default_title": "ReadFluent Capture"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["activeTab", "scripting", "storage", "tabs", "sidePanel", "contextMenus"],
  "host_permissions": ["http://127.0.0.1:8000/*", "http://localhost:8000/*", "https://*/*", "http://*/*"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
